{
  "name": "r2-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate-types": "wrangler types && openapi-typescript ./openapi/vuefinder.yaml --output ./openapi/vuefinder.d.ts",
    "type-check": "generate-types && tsc"
  },
  "dependencies": {
    "itty-router": "^5.0.24",
    "fflate": "^0.8.3",
    "vue": "^3.5.21",
    "vuefinder": "^4.5.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.103.0"
  }
}
